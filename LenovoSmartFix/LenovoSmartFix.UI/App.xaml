<Application
    x:Class="LenovoSmartFix.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LenovoSmartFix.UI.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary>

                    <!-- ── Colour palette ──────────────────────────── -->
                    <Color x:Key="LenovoRed">#E1140A</Color>
                    <Color x:Key="SurfaceBackground">#F5F5F5</Color>
                    <Color x:Key="CardBackground">#FFFFFF</Color>
                    <Color x:Key="TextPrimary">#1A1A1A</Color>
                    <Color x:Key="TextSecondary">#6B6B6B</Color>
                    <Color x:Key="SuccessGreen">#1E7E34</Color>
                    <Color x:Key="WarningAmber">#D97706</Color>
                    <Color x:Key="ErrorRed">#E1140A</Color>

                    <SolidColorBrush x:Key="LenovoRedBrush"           Color="{StaticResource LenovoRed}" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush"   Color="{StaticResource SurfaceBackground}" />
                    <SolidColorBrush x:Key="CardBackgroundBrush"      Color="{StaticResource CardBackground}" />
                    <SolidColorBrush x:Key="TextPrimaryBrush"         Color="{StaticResource TextPrimary}" />
                    <SolidColorBrush x:Key="TextSecondaryBrush"       Color="{StaticResource TextSecondary}" />
                    <SolidColorBrush x:Key="SuccessGreenBrush"        Color="{StaticResource SuccessGreen}" />
                    <SolidColorBrush x:Key="WarningAmberBrush"        Color="{StaticResource WarningAmber}" />
                    <SolidColorBrush x:Key="ErrorRedBrush"            Color="{StaticResource ErrorRed}" />

                    <!-- ── Converters ───────────────────────────────── -->
                    <conv:PercentConverter           x:Key="PercentConverter" />
                    <conv:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter" />
                    <conv:NotVisibilityConverter     x:Key="NotVisibilityConverter" />
                    <conv:NotConverter               x:Key="NotConverter" />
                    <conv:ZeroToVisibleConverter     x:Key="ZeroToVisibleConverter" />
                    <conv:BoolToColorConverter       x:Key="BoolToColorConverter" />
                    <conv:ConsentToButtonTextConverter x:Key="ConsentToButtonTextConverter" />

                    <!-- ── Card style ────────────────────────────────── -->
                    <Style x:Key="SmartFixCard" TargetType="Border">
                        <Setter Property="Background"       Value="{StaticResource CardBackgroundBrush}" />
                        <Setter Property="CornerRadius"     Value="0" />
                        <Setter Property="Padding"          Value="16" />
                        <Setter Property="BorderBrush"      Value="#E0E0E0" />
                        <Setter Property="BorderThickness"  Value="1" />
                        <Setter Property="Margin"           Value="0,0,0,12" />
                    </Style>

                    <!-- ── Section header ────────────────────────────── -->
                    <Style x:Key="SectionHeader" TargetType="TextBlock">
                        <Setter Property="FontSize"   Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Margin"     Value="0,0,0,10" />
                    </Style>

                    <!-- ── Status badge ──────────────────────────────── -->
                    <Style x:Key="StatusBadge" TargetType="Border">
                        <Setter Property="Background"   Value="{StaticResource LenovoRedBrush}" />
                        <Setter Property="CornerRadius" Value="2" />
                        <Setter Property="Padding"      Value="6,2" />
                    </Style>

                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<Page
    x:Class="LenovoSmartFix.UI.Pages.EscalationPacketPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource SurfaceBackgroundBrush}">

    <ScrollViewer Padding="32">
        <StackPanel MaxWidth="680" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Support Packet" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="SmartFix has prepared a structured summary. Share it with Lenovo Support to skip first-line diagnostics."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Packet summary -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Summary" Style="{StaticResource SectionHeader}" />

                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Issue" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Symptom, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Outcome" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Outcome, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Unresolved" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.UnresolvedReason, Mode=OneWay}"
                                   FontSize="12" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Privacy control -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Privacy" Style="{StaticResource SectionHeader}" />
                    <ToggleSwitch Header="Include device serial number and personal identifiers"
                                  IsOn="{x:Bind ViewModel.IncludePersonalData, Mode=TwoWay}"
                                  FontSize="12" />
                    <TextBlock Text="By default, serial numbers and device IDs are redacted. Only diagnostic metadata is included."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Export -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Export" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="Exports a JSON file (machine-readable) and a PDF summary (shareable)."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />

                    <Button Content="Export Support Packet"
                            Height="40" FontSize="13" FontWeight="SemiBold"
                            Background="{StaticResource LenovoRedBrush}" Foreground="White"
                            CornerRadius="0"
                            Command="{x:Bind ViewModel.ExportCommand}" />

                    <!-- Export result -->
                    <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.ExportCompleted, Mode=OneWay}">
                        <TextBlock Text="Exported successfully."
                                   FontSize="12" Foreground="{StaticResource SuccessGreenBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ExportedJsonPath, Mode=OneWay}"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Button Content="Open Folder" CornerRadius="0"
                                Command="{x:Bind ViewModel.OpenExportFolderCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status / loading -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="18" Height="18" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

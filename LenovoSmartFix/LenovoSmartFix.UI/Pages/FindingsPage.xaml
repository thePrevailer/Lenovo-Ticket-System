<Page
    x:Class="LenovoSmartFix.UI.Pages.FindingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource SurfaceBackgroundBrush}">

    <ScrollViewer Padding="32">
        <StackPanel MaxWidth="720" Spacing="20">

            <!-- Page header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Findings" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Here is what SmartFix found on your device."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Diagnosis verdict -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Diagnosis" Style="{StaticResource SectionHeader}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Style="{StaticResource StatusBadge}">
                            <TextBlock Text="{x:Bind ViewModel.DiagnosisPath, Mode=OneWay}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.DiagnosisReason, Mode=OneWay}"
                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Device -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Device" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind ViewModel.DeviceModel, Mode=OneWay}"
                                   FontSize="12" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="OS" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind ViewModel.OsInfo, Mode=OneWay}"
                                   FontSize="12" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="BIOS" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{x:Bind ViewModel.BiosVersion, Mode=OneWay}"
                                   FontSize="12" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Health snapshot -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Health Snapshot" Style="{StaticResource SectionHeader}" />

                    <ItemsControl>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                               FontSize="12" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Inline health rows -->
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Battery" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.BatteryStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Disk" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DiskStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="RAM" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.RamStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="CPU" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CpuStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Wi-Fi" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.WifiStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                    <Grid ColumnSpacing="12" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBlock Text="Crashes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CrashStatus, Mode=OneWay}" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Update status -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Software Stack" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="{x:Bind ViewModel.UpdateSummary, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{x:Bind ViewModel.HasUpdates, Converter={StaticResource BoolToColorConverter}, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="View Resolution Options"
                        Height="40" FontSize="13" FontWeight="SemiBold"
                        Background="{StaticResource LenovoRedBrush}" Foreground="White"
                        CornerRadius="0"
                        Command="{x:Bind ViewModel.ViewResolutionOptionsCommand}" />
                <Button Content="Prepare Support Packet"
                        Height="40" FontSize="13"
                        CornerRadius="0"
                        Command="{x:Bind ViewModel.ViewEscalationPacketCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

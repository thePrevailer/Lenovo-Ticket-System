<Page
    x:Class="LenovoSmartFix.UI.Pages.ResolutionCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LenovoSmartFix.UI.ViewModels"
    Background="{StaticResource SurfaceBackgroundBrush}">

    <ScrollViewer Padding="32">
        <StackPanel MaxWidth="720" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Resolution Center" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{x:Bind ViewModel.DiagnosisReason, Mode=OneWay}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Action list -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.Actions, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ActionItem">
                        <Border Style="{StaticResource SmartFixCard}" Margin="0,0,0,8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind ActionName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <Border Background="#F0F0F0" CornerRadius="2" Padding="4,1">
                                            <TextBlock Text="{x:Bind SafetyBadge}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <!-- Result -->
                                    <TextBlock Text="{x:Bind ResultDetail, Mode=OneWay}"
                                               FontSize="11" Foreground="{StaticResource SuccessGreenBrush}"
                                               Visibility="{x:Bind IsCompleted, Mode=OneWay}" />
                                </StackPanel>

                                <!-- Execute button -->
                                <Button Grid.Column="1"
                                        Content="{x:Bind RequiresConsent, Converter={StaticResource ConsentToButtonTextConverter}}"
                                        VerticalAlignment="Center"
                                        IsEnabled="{x:Bind IsExecuting, Mode=OneWay, Converter={StaticResource NotConverter}}"
                                        Command="{Binding DataContext.ExecuteActionCommand, ElementName=ActionsList}"
                                        CommandParameter="{Binding}"
                                        CornerRadius="0"
                                        MinWidth="110" />
            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- No actions -->
            <Border Style="{StaticResource SmartFixCard}"
                    Visibility="{x:Bind ViewModel.Actions.Count, Converter={StaticResource ZeroToVisibleConverter}, Mode=OneWay}">
                <TextBlock Text="No automated actions available for this issue. Use the support packet to escalate."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Escalation link -->
            <Button Content="Prepare Support Packet"
                    Height="40" FontSize="13" CornerRadius="0"
                    Command="{x:Bind ViewModel.GoToEscalationCommand}" />
        </StackPanel>
    </ScrollViewer>
</Page>

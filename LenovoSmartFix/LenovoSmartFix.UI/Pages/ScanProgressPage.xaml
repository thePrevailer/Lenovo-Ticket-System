<Page
    x:Class="LenovoSmartFix.UI.Pages.ScanProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource SurfaceBackgroundBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
          MaxWidth="520" Padding="32">
        <StackPanel Spacing="24">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Scanning Your Device"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="SmartFix is collecting health data and checking your software stack."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Progress bar -->
            <StackPanel Spacing="6">
                <ProgressBar x:Name="ScanProgress"
                             Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                             Maximum="100"
                             Height="6"
                             Foreground="{StaticResource LenovoRedBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Space-Between">
                    <TextBlock Text="{x:Bind ViewModel.CurrentStep, Mode=OneWay}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressPercent, Mode=OneWay, Converter={StaticResource PercentConverter}}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </StackPanel>

            <!-- Steps indicator -->
            <Border Style="{StaticResource SmartFixCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Checking" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="· Device identity and hardware profile" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="· Battery, disk, memory, CPU, Wi-Fi" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="· BIOS, firmware, and driver versions" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="· Crash and stability history" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="· Applying safe automatic fixes" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Error state -->
            <Border Style="{StaticResource SmartFixCard}"
                    Visibility="{x:Bind ViewModel.ScanFailed, Mode=OneWay}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Scan could not complete"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorRedBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Button Content="Try Again" CornerRadius="0"
                            Click="RetryButton_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
